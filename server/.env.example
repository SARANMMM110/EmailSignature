SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_STORAGE_BUCKET=signature-images
# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, POST /api/generate-signature uploads PNGs to
# this bucket under generated-signatures/ and returns a public Supabase URL (best for email clients).
PORT=3001
CLIENT_URL=http://localhost:5173

# HTTPS origin where /signatures/* is reachable by email recipients (Gmail loads <img src> from here).
# Required for linked signatures in sent mail when the PNG is not inlined. Use ngrok or your production host.
# PUBLIC_BASE_URL=https://your-domain.com

# Optional: prefix for root-relative /img/... URLs inside generated signature HTML (email clients).
# SIGNATURE_PUBLIC_ASSET_BASE=https://your-domain.com

# Local dev only: API treats all users as Pro (extra signatures, pro templates). Remove in production.
# DEV_USER_PLAN_OVERRIDE=pro
