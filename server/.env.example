SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_STORAGE_BUCKET=signature-images
# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, POST /api/generate-signature uploads PNGs to
# this bucket under generated-signatures/ and returns a public Supabase URL (best for email clients).
PORT=3001
CLIENT_URL=http://localhost:5173

# Admin panel (/admin) uses username + password stored in `public.admin_app_credentials` (see migration 045).
# First boot seeds demo login: username `admin` / password `AdminDemo!2026` — change under Admin → Account.
# Sign JWTs for admin sessions (use a long random string in production).
# ADMIN_JWT_SECRET=replace-with-long-random-secret

# HTTPS origin where /signatures/* is reachable by email recipients (Gmail loads <img src> from here).
# Required for linked signatures in sent mail when the PNG is not inlined. Use ngrok or your production host.
# PUBLIC_BASE_URL=https://your-domain.com

# Optional: prefix for root-relative /img/... URLs inside generated signature HTML (email clients).
# SIGNATURE_PUBLIC_ASSET_BASE=https://your-domain.com

# Local dev only: API treats all users as Pro (extra signatures, pro templates). Remove in production.
# DEV_USER_PLAN_OVERRIDE=pro

# Puppeteer (POST /api/generate-signature — copy image / PNG export): bundled Chrome needs OS libs on Linux.
# If you see "libnspr4.so: cannot open shared object file", install deps on the server, then restart PM2:
#   sudo apt-get update && sudo apt-get install -y libnspr4 libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
#     libdrm2 libgbm1 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 libasound2 libpango-1.0-0 libcairo2 libgtk-3-0
# Optional: use system Chromium instead of Puppeteer's download (after: apt install chromium-browser or chromium):
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
