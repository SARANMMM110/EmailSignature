VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
VITE_API_URL=http://localhost:3001

# Same public origin as PUBLIC_BASE_URL — rewrites <img src> in paste HTML when the API still returns localhost.
# VITE_PUBLIC_SIGNATURE_IMAGE_BASE=https://your-domain.com

# Local dev only: UI shows Pro (matches server if you set DEV_USER_PLAN_OVERRIDE=pro). Remove in production.
# VITE_DEV_USER_PLAN_OVERRIDE=pro

# Optional: only after enabling Google in Supabase → Authentication → Providers
# VITE_ENABLE_GOOGLE_AUTH=true
