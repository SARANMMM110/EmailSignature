VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Full URL with scheme (never use a path like `/api` alone — production would resolve API calls wrong on /dashboard etc.).
# Production same host: https://signaturestudio.biz   |   Dev default below points at local Express.
VITE_API_URL=http://localhost:3001
# Rare: API on another hostname (e.g. https://api.example.com) while SPA is on https://example.com — set at build:
# VITE_API_CROSS_ORIGIN=true

# Same public origin as PUBLIC_BASE_URL — rewrites <img src> in paste HTML when the API still returns localhost.
# VITE_PUBLIC_SIGNATURE_IMAGE_BASE=https://your-domain.com

# Local dev ONLY (ignored in production builds). If set, overrides profiles.plan for plan gates (limits, upgrade prompts);
# the sidebar "Current plan" label still reflects the database tier. Leave unset unless you are deliberately testing another tier.
# Legacy values: free→Personal, pro→Advanced, business→Ultimate.
# VITE_DEV_USER_PLAN_OVERRIDE=personal

# Stripe Price IDs (optional — wire when checkout is ready)
# VITE_STRIPE_PERSONAL_MONTHLY=
# VITE_STRIPE_PERSONAL_YEARLY=
# VITE_STRIPE_ADVANCED_MONTHLY=
# VITE_STRIPE_ADVANCED_YEARLY=
# VITE_STRIPE_ULTIMATE_MONTHLY=
# VITE_STRIPE_ULTIMATE_YEARLY=

# Optional: only after enabling Google in Supabase → Authentication → Providers
# VITE_ENABLE_GOOGLE_AUTH=true

# Optional: floating support button. Use https://… for chat/docs, or mailto:… for email. If unset, defaults to email.
# VITE_SUPPORT_URL=https://your-help-site.example/contact
